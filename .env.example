# Plantilla de variables de entorno para sistema-bancario-java.
#
# Uso:
#   1. Copia este archivo a .env (cp .env.example .env).
#   2. Edita los valores que quieras personalizar.
#   3. Tanto `docker compose up` como la app Java leen estas variables.
#
# Si NO creas .env, la app igual funciona usando los defaults definidos en
# docker-compose.yml y src/main/resources/application.properties.
#
# El archivo .env está ignorado por git (ver .gitignore) — nunca lo commitees.

POSTGRES_DB=changeme
POSTGRES_USER=changeme
POSTGRES_PASSWORD=changeme
